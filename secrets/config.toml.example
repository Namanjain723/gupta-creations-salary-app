# Copy this file to  secrets/config.toml  and fill in your real IDs.
# (When deploying on Streamlit Community Cloud, paste this whole block into
#  the app's  Settings -> Secrets  text box instead — same format.)

[sheets]
# The Google Sheet that holds all 11 tabs (Employee_Master, Biometric_Raw, ...).
# Get the ID from the sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_LONG_ID_HERE/edit
salary_db_id = "PASTE_YOUR_SALARY_SHEET_ID_HERE"

# OPTIONAL — only if commissions live in a *separate* spreadsheet (Option B).
# Leave blank to read SALE_REPORT_KN from the same salary sheet (Option A, recommended).
kn_sales_id = ""

[app]
default_location = "KAMLA NAGAR"
admin_name = "Admin"

# Team logins for the shared link. Add one line per person (username = password).
# Anyone listed under viewers is read-only (can view, cannot edit/run payroll).
[auth.users]
naman = "CHANGE-ME-strong-pass"
manager = "CHANGE-ME-another-pass"
# accountant = "..."

[auth]
viewers = ["accountant"]   # read-only usernames (optional)

# When deploying to Streamlit Cloud you paste the service-account JSON here too,
# under a [gcp_service_account] table. Locally we read secrets/service_account.json.
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# token_uri = "https://oauth2.googleapis.com/token"
